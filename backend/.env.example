# 백엔드 환경 변수 예시 (.env 로 복사 후 값 채우기)

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Claude API (영수증 파싱 / 카테고리 분류 / 챗봇)
ANTHROPIC_API_KEY=

# Kakao Local API (주소 / 상호 보정)
KAKAO_API_KEY=

# JWT 인증
# JWT_SECRET: 토큰 서명 비밀키. 반드시 길고 임의의 값으로 지정할 것.
#   생성 예) python -c "import secrets; print(secrets.token_urlsafe(64))"
#   미설정/비움이면 서버가 프로세스마다 임의 키를 생성한다(재시작 시 토큰 무효화 → 재로그인).
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 허용 출처 (콤마 구분). 미설정 시 http://localhost:5173.
# 배포/터널 데모: 프론트 주소 지정(예: https://app.example.com) 또는 "*"(임시 전체 허용)
CORS_ORIGINS=http://localhost:5173
