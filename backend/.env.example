# 백엔드 환경 변수 예시 (.env 로 복사 후 값 채우기)

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Claude API (영수증 파싱 / 카테고리 분류 / 챗봇)
ANTHROPIC_API_KEY=

# Kakao Local API (주소 / 상호 보정)
KAKAO_API_KEY=

# JWT 인증
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 허용 출처 (콤마 구분). 미설정 시 http://localhost:5173.
# 배포/터널 데모: 프론트 주소 지정(예: https://app.example.com) 또는 "*"(임시 전체 허용)
CORS_ORIGINS=http://localhost:5173
